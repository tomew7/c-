int trig = 10;
int eco = 9;
int led = 3;

long duracion;
int distancia;

void setup() {
  pinMode(trig, OUTPUT);
  pinMode(eco, INPUT);
  pinMode(led, OUTPUT);
  Serial.begin(9600);
}

void loop() {
  // Pulso correcto del sensor
  digitalWrite(trig, LOW);
  delayMicroseconds(2);
  digitalWrite(trig, HIGH);
  delayMicroseconds(10);
  digitalWrite(trig, LOW);

  // Lectura
  duracion = pulseIn(eco, HIGH);
  distancia = duracion / 58;

  Serial.println(distancia);
  delay(200);

  // Condición corregida
  if (distancia <= 20 && distancia >= 0) {
    digitalWrite(led, HIGH);
    delay(distancia * 10);
    digitalWrite(led, LOW);
  }
}
